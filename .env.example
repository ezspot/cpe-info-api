# Server
ADDR=:8080
LOG_LEVEL=INFO

# API auth (optional)
CPE_API_KEY=""

# Allowed target ranges
CPE_ALLOWED_TARGET_CIDRS=192.168.0.0/16,10.0.0.0/8

# Capacity/timeouts
CPE_CONCURRENCY=16
CPE_REQUEST_TIMEOUT=45s
CPE_SSH_DIAL_TIMEOUT=6s
CPE_SSH_CMD_TIMEOUT=12s

# Generic SSH fallback (used for unknown models)
CPE_SSH_USER=root
CPE_SSH_PASS=
CPE_SSH_KEY_PATH=
# Optional passphrase when CPE_SSH_KEY_PATH points to an encrypted private key
CPE_SSH_KEY_PASSPHRASE=

# Model key lookup
CPE_SSH_KEYS_DIR=cpe-ssh-keys
CPE_SSH_MODEL_KEY_MAP=

# VANTIVA OpenWRT model credentials (required for models such as F01, F1X, and VANTIVA)
# VANTIVA tries key + password; if key cannot be parsed, password auth is still attempted.
VANTIVA_CPE_CLI_USER=
VANTIVA_CPE_CLI_PASSWORD=

# Host key verification (recommended)
CPE_SSH_KNOWN_HOSTS=C:/Users/<user>/.ssh/known_hosts
CPE_SSH_INSECURE_HOSTKEY=false
